@page "/librarian/loans"
@using LibrarySystem.Client.Models
@using LibrarySystem.Client.Services
@inject LoanService LoanService
@inject BookService BookService
@inject ReaderService ReaderService

<PageTitle>Kölcsönzések Kezelése</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Könyvtári Nyilvántartás - Kölcsönzések</h2>

    @* ÚJ KÖLCSÖNZÉS FELVÉTELE *@
    <div class="card mb-4 shadow-sm border-primary">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Új kölcsönzés rögzítése</h5>
        </div>
        <div class="card-body">
            <EditForm Model="@newLoan" OnValidSubmit="CreateLoan">
                <DataAnnotationsValidator />
                
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Olvasó</label>
                        <select class="form-select" @bind="newLoan.ReaderNumber">
                            <option value="0">-- Válasszon olvasót --</option>
                            @if (readers != null)
                            {
                                @foreach (var r in readers)
                                {
                                    <option value="@r.ReaderNumber">@r.Name (@r.ReaderNumber)</option>
                                }
                            }
                        </select>
                        <ValidationMessage For="@(() => newLoan.ReaderNumber)" class="text-danger" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Könyv</label>
                        <select class="form-select" @bind="newLoan.BookInventoryNumber">
                            <option value="0">-- Válasszon könyvet --</option>
                            @if (availableBooks != null)
                            {
                                @foreach (var b in availableBooks)
                                {
                                    <option value="@b.InventoryNumber">@b.Title (@b.InventoryNumber)</option>
                                }
                            }
                        </select>
                        <ValidationMessage For="@(() => newLoan.BookInventoryNumber)" class="text-danger" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Kölcsönzés dátuma</label>
                        <InputDate @bind-Value="newLoan.LoanDate" class="form-control" />
                        <ValidationMessage For="@(() => newLoan.LoanDate)" class="text-danger" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Visszahozási határidő</label>
                        <InputDate @bind-Value="newLoan.ReturnDeadline" class="form-control" />
                        <ValidationMessage For="@(() => newLoan.ReturnDeadline)" class="text-danger" />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary" disabled="@(newLoan.ReaderNumber == 0 || newLoan.BookInventoryNumber == 0)">Kölcsönzés indítása</button>
                </div>
            </EditForm>
        </div>
    </div>

    @* LISTA *@
    @if (loans == null)
    {
        <div class="text-center"><p><em>Betöltés...</em></p></div>
    }
    else
    {
        <table class="table table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Olvasó</th>
                    <th>Könyv</th>
                    <th>Kezdete</th>
                    <th>Határidő</th>
                    <th>Késedelmi díj</th>
                    <th>Művelet</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in loans)
                {
                    <tr class="@(loan.PenaltyFee > 0 ? "table-danger" : "")">
                        <td>@loan.ReaderNumber</td>
                        <td>@loan.BookInventoryNumber</td>
                        <td>@loan.LoanDate.ToShortDateString()</td>
                        <td>@loan.ReturnDeadline.ToShortDateString()</td>
                        <td class="fw-bold text-danger">@(loan.PenaltyFee > 0 ? $"{loan.PenaltyFee} Ft" : "-")</td>
                        <td>
                            <button class="btn btn-sm btn-success" @onclick="() => ReturnBook(loan.LoanId)">Visszahozva</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Loan>? loans;
    private List<Reader>? readers;
    private List<Book>? availableBooks;
    private Loan newLoan = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loans = await LoanService.GetLoansAsync();
        readers = await ReaderService.GetReadersAsync();
        availableBooks = await BookService.GetAvailableBooksAsync();
    }

    private async Task CreateLoan()
    {
        await LoanService.AddLoanAsync(newLoan);
        newLoan = new Loan(); // Form alaphelyzetbe
        await LoadData();
    }

    private async Task ReturnBook(int id)
    {
        await LoanService.ReturnBookAsync(id);
        await LoadData();
    }
}